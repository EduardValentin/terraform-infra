enable_github = true
github_owner  = "EduardValentin"
github_token  = "ghp_replace"

github_repository_environments = {
  "course-platform" = ["test", "production"]
}

github_repository_variables = {
  "course-platform" = {
    TEST_NODE_HOSTNAME = "susanoo-test.longhair-eagle.ts.net"
    PROD_NODE_HOSTNAME = "courseplatform-prod.longhair-eagle.ts.net"
    TEST_APP_HOSTNAME = "susanoo-test.longhair-eagle.ts.net"
    TEST_APP_BASE_PATH = "/courseplatform"
    PROD_APP_HOSTNAME = "courseplatform.com"
    PROD_APP_BASE_PATH = "/"
  }
  "terraform-infra" = {
    TEST_NODE_HOSTNAME = "susanoo-test.longhair-eagle.ts.net"
    PROD_NODE_HOSTNAME = "courseplatform-prod.longhair-eagle.ts.net"
  }
}

github_repository_secrets = {
  "course-platform" = {
    TAILSCALE_OAUTH_CLIENT_ID = "oauth-client-id-replace"
    TAILSCALE_OAUTH_SECRET    = "oauth-client-secret-replace"
    TEST_SSH_KNOWN_HOSTS     = "test-host.tailnet.ts.net ssh-ed25519 AAAA..."
    PROD_SSH_KNOWN_HOSTS     = "prod-host.tailnet.ts.net ssh-ed25519 AAAA..."
    GHCR_PULL_USERNAME       = "EduardValentin"
    GHCR_PULL_TOKEN          = "github_pat_replace"
  }
  "terraform-infra" = {
    TAILSCALE_OAUTH_CLIENT_ID      = "oauth-client-id-replace"
    TAILSCALE_OAUTH_SECRET         = "oauth-client-secret-replace"
    TEST_SSH_KNOWN_HOSTS           = "test-host.tailnet.ts.net ssh-ed25519 AAAA..."
    PROD_SSH_KNOWN_HOSTS           = "prod-host.tailnet.ts.net ssh-ed25519 AAAA..."
    SOPS_AGE_KEY                   = "AGE-SECRET-KEY-1..."
  }
}

github_environment_variables = {
  "course-platform" = {
    "test" = {
      APP_ENV = "test"
    }
    "production" = {
      APP_ENV = "prod"
    }
  }
}

github_environment_secrets = {
  "course-platform" = {
    "test" = {
      TEST_DEPLOY_USER = "root"
    }
    "production" = {
      PROD_DEPLOY_USER = "root"
    }
  }
}

enable_tailscale_policy     = true
tailscale_tailnet           = "longhair-eagle.ts.net"
tailscale_oauth_client_id   = "oauth-client-id-replace"
tailscale_oauth_client_secret = "oauth-client-secret-replace"
tailscale_admin_group       = "group:admin"
tailscale_ci_terraform_sources = ["tag:ci-terraform"]
tailscale_ci_terraform_destinations = ["tag:ops:9000"]
tailscale_ci_secrets_sources = ["tag:ci-secrets"]
tailscale_ci_secrets_destinations = ["tag:test:22", "tag:prod:22"]
tailscale_ci_app_sources = ["tag:ci-app-deploy"]
tailscale_ci_app_destinations = ["tag:test:22", "tag:prod:22"]
tailscale_admin_destinations = ["*:*"]
tailscale_opencl_agent_tag = "tag:solus-agent"
tailscale_opencl_agent_tag_owners = ["solus.assistant@gmail.com"]
tailscale_opencl_account_sources = ["solus.assistant@gmail.com"]
tailscale_opencl_account_destinations = [
  "tag:test:443",
  "tag:test:8080",
  "tag:test:9100",
  "tag:ops:3000",
  "tag:ops:9090",
  "tag:ops:3100",
  "tag:ops:3200",
  "tag:ops:4317",
  "tag:ops:4318",
  "tag:ops:18080",
  "tag:ops:19100"
]
tailscale_opencl_agent_sources = ["tag:solus-agent"]
tailscale_opencl_agent_destinations = [
  "tag:test:443",
  "tag:test:8080",
  "tag:test:9100",
  "tag:ops:3000",
  "tag:ops:9090",
  "tag:ops:3100",
  "tag:ops:3200",
  "tag:ops:4317",
  "tag:ops:4318",
  "tag:ops:18080",
  "tag:ops:19100"
]
tailscale_opencl_admin_sources = ["eduard.valentin1996@gmail.com"]
tailscale_opencl_admin_destinations = ["tag:solus-agent:*"]
tailscale_regular_member_sources = ["eli.lungu04@gmail.com"]
tailscale_regular_member_destinations = ["*:*"]

tailnet_name            = "longhair-eagle.ts.net"
placeholder_prod_domain = "courseplatform.com"
app_names               = ["courseplatform"]

app_brand_domains = {
  courseplatform = ["courseplatform.com"]
}

bootstrap_template_app_name      = "courseplatform"
bootstrap_hostname_test          = "susanoo-test"
bootstrap_hostname_ops           = "susanoo-ops"
bootstrap_hostname_prod          = "courseplatform-prod"
bootstrap_tailscale_auth_key_test = "tskey-replace"
bootstrap_tailscale_auth_key_ops  = "tskey-replace"
bootstrap_tailscale_auth_key_prod = "tskey-replace"
bootstrap_tailscale_tags_test    = "tag:test"
bootstrap_tailscale_tags_ops     = "tag:ops"
bootstrap_tailscale_tags_prod    = "tag:prod"
ops_loki_host                    = "susanoo-ops.longhair-eagle.ts.net"
ops_test_hosts                   = ["susanoo-test.longhair-eagle.ts.net"]
ops_prod_hosts                   = []
ops_low_resource_mode            = false
ops_grafana_admin_password       = "replace-with-strong-password"
ops_terraform_backend_enabled    = true
ops_terraform_backend_bucket     = "terraform-state"
ops_terraform_backend_bind_ip    = ""
ops_terraform_backend_port       = 9000
ops_terraform_backend_access_key = "terraform-state"
ops_terraform_backend_secret_key = "replace-with-strong-secret"

prod_pg_backup_enabled            = true
prod_pg_backup_oncalendar         = "*-*-* 03:15:00"
prod_pg_backup_local_dir          = "/srv/backups/postgres"
prod_pg_backup_local_retention_days = 14
prod_pg_backup_nas_dir            = "/mnt/nas/courseplatform-backups"
prod_pg_backup_nas_retention_days = 14
