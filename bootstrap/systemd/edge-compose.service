[Unit]
Description=Start apphost edge compose stack
After=network-online.target docker.service
Wants=network-online.target docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/docker compose --env-file /srv/edge/.env -f /srv/edge/docker-compose.yml up -d

[Install]
WantedBy=multi-user.target
