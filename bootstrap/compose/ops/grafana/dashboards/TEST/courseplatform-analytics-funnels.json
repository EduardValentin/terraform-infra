{
  "id": null,
  "uid": "cp-test-analytics-funnels",
  "title": "Course Platform TEST Analytics Funnels",
  "tags": ["course-platform", "test", "ops", "analytics"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "description": "Business analytics funnels and conversion indicators for TEST.",
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Environment",
        "type": "constant",
        "query": "test",
        "current": { "text": "test", "value": "test" }
      },
      {
        "name": "app",
        "label": "App",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{env=\"test\"}, app)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": ".*" }
      },
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up{env=\"test\",app=~\"$app\"}, host)",
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": ".*" }
      }
    ]
  },
  "panels": [
    {
      "type": "text",
      "title": "Analytics Scope",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<h2>ENV: TEST</h2><p>Checkout, purchase, auth and webhook analytics derived from Prometheus counters.</p>"
      }
    },
    {
      "type": "stat",
      "title": "Checkout Success Rate (15m)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(courseplatform_checkout_flow_events_total{env=\"test\",app=~\"$app\",host=~\"$host\",outcome=\"success\"}[15m])) / clamp_min(sum(rate(courseplatform_checkout_flow_events_total{env=\"test\",app=~\"$app\",host=~\"$host\"}[15m])), 0.001))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Purchase Success Rate (15m)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(courseplatform_purchase_fulfillments_total{env=\"test\",app=~\"$app\",host=~\"$host\",outcome=\"success\"}[15m])) / clamp_min(sum(rate(courseplatform_purchase_fulfillments_total{env=\"test\",app=~\"$app\",host=~\"$host\"}[15m])), 0.001))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Auth Callback Success Rate (15m)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(courseplatform_auth_callbacks_total{env=\"test\",app=~\"$app\",host=~\"$host\",outcome=\"success\"}[15m])) / clamp_min(sum(rate(courseplatform_auth_callbacks_total{env=\"test\",app=~\"$app\",host=~\"$host\"}[15m])), 0.001))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Stripe Webhook Success Rate (15m)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(courseplatform_stripe_webhook_events_total{env=\"test\",app=~\"$app\",host=~\"$host\",outcome=\"success\"}[15m])) / clamp_min(sum(rate(courseplatform_stripe_webhook_events_total{env=\"test\",app=~\"$app\",host=~\"$host\"}[15m])), 0.001))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Checkout Events by Flow/Outcome",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (flow, outcome) (rate(courseplatform_checkout_flow_events_total{env=\"test\",app=~\"$app\",host=~\"$host\"}[15m]))",
          "legendFormat": "{{flow}} {{outcome}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Purchase Fulfillments by Source/Outcome",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (source, outcome) (rate(courseplatform_purchase_fulfillments_total{env=\"test\",app=~\"$app\",host=~\"$host\"}[15m]))",
          "legendFormat": "{{source}} {{outcome}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth Callback Outcomes",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome) (rate(courseplatform_auth_callbacks_total{env=\"test\",app=~\"$app\",host=~\"$host\"}[15m]))",
          "legendFormat": "auth {{outcome}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Stripe Webhook Outcomes by Event Type",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event_type, outcome) (rate(courseplatform_stripe_webhook_events_total{env=\"test\",app=~\"$app\",host=~\"$host\"}[15m]))",
          "legendFormat": "{{event_type}} {{outcome}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Exercise Submission Outcomes",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (mode, outcome) (rate(courseplatform_exercise_submissions_total{env=\"test\",app=~\"$app\",host=~\"$host\"}[15m]))",
          "legendFormat": "{{mode}} {{outcome}}"
        }
      ]
    }
  ]
}
